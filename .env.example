# AI Provider
# Leave empty to auto-detect (uses Ollama if no ANTHROPIC_API_KEY, else Anthropic)
# AI_PROVIDER=ollama

# For Anthropic Claude (optional — requires paid API key)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama Settings (default, no API key needed) ---
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT=60
